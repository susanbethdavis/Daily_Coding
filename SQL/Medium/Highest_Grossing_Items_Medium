  EXTRACT(YEAR FROM transaction_date) = 2022
  
  This query will not work because you I am mixing individual rows and aggregated rows.
  In SQL, you generally cannot nest an aggregate function directly inside a window FUNCTION
  unless you are also using a GROUP BY clause. 
  
  Here is why the database id confused:
  1. The Window Function(RANK): Ezxpects to look at every individual row in your TABLE
  2. The aggregate (SUM): Tell the database to squish multiple rows into one total
*/

SELECT 
  category, 
  product,
  total_spend
FROM (
    SELECT 
      category, 
      product, 
      SUM(spend) as total_spend,
      RANK() OVER (
      PARTITION BY category
      ORDER BY SUM(spend) DESC) as rank_alias
    FROM product_spend 
    WHERE 
      EXTRACT(YEAR FROM transaction_date) = 2022
    GROUP BY 
      category, product)
    AS ranked_spending
WHERE
  rank_alias <=2

